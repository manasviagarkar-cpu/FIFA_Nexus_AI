# ============================================================================
# FIFA Nexus AI — Environment Configuration
# Copy this file to .env and update values for your environment
# ============================================================================

# Database
POSTGRES_DB=fifa_nexus
POSTGRES_USER=nexus_admin
POSTGRES_PASSWORD=nexus_secure_2026
POSTGRES_PORT=5432

# Redis
REDIS_PASSWORD=nexus_redis_2026
REDIS_PORT=6379

# JWT Authentication
JWT_SECRET=fifa-nexus-jwt-secret-2026-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# Service Ports
WAYFINDING_PORT=8001
CROWD_MGMT_PORT=8002
FAN_ASSIST_PORT=8003

# Gemini AI (Fan Assistance)
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.5-pro

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# Logging
LOG_LEVEL=info

# Rate Limiting
RATE_LIMIT_FAN=100
RATE_LIMIT_STAFF=500
RATE_LIMIT_ADMIN=1000
RATE_LIMIT_WINDOW_SECONDS=60
